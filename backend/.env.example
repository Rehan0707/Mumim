# Munim.ai backend config. Copy to .env and fill for real integrations.
# For the pragmatic MVP everything works with mock defaults — no keys required.

# --- app ---
APP_ENV=development          # development | production
LOG_LEVEL=INFO               # DEBUG | INFO | WARNING | ERROR
FRONTEND_ORIGIN=http://localhost:5173
PUBLIC_BASE_URL=
APP_SECRET=change-me-to-a-32-character-random-secret
AUTH_REQUIRED=false           # defaults to true when APP_ENV=production
TOKEN_TTL_SECONDS=604800
ALLOW_MOCK_AI=true            # set false in production unless demoing
ALLOW_PRODUCTION_MOCKS=false  # never enable for real customers

# --- external APIs ---
# GROQ_API_KEY=                 # optional: set for LLM conversational fallback (llama-3.1-8b-instant)

# --- database (Neon PostgreSQL Cloud) ---
# DATABASE_URL=postgresql+psycopg://[USER]:[PASSWORD]@[NEON_HOST]/neondb?sslmode=require

# --- payments: "mock" (default) or "razorpay" ---
PAYMENT_MODE=mock
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# --- whatsapp: "mock" (simulator) or "twilio" ---
WHATSAPP_MODE=mock
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=+14155238886   # Twilio Sandbox number
