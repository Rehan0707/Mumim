# Munim.ai backend config. Copy to .env and fill for real integrations.
# For the pragmatic MVP everything works with mock defaults — no keys required.

# Database (SQLite for dev; swap to postgresql+psycopg://... for pgvector later)
DATABASE_URL=sqlite:///./munim.db

# Payment mode: "mock" (default) or "razorpay"
PAYMENT_MODE=mock
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# WhatsApp mode: "mock" (simulator) or "twilio"
WHATSAPP_MODE=mock
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=

# CORS origin for the frontend dev server
FRONTEND_ORIGIN=http://localhost:5173
